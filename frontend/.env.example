# --- LitZap frontend env (copy to .env.local and fill in) ---

# LiteForge (LitVM) RPC
NEXT_PUBLIC_LITEFORGE_RPC=https://liteforge.rpc.caldera.xyz/http

# Deployed contract addresses (chain 4441)
NEXT_PUBLIC_REGISTRY=0x...
NEXT_PUBLIC_PAY=0x...
NEXT_PUBLIC_CAPSULE=0x...
NEXT_PUBLIC_SUBS=0x...
NEXT_PUBLIC_ESCROW=0x...

# Tokens
NEXT_PUBLIC_USDC=0x...

# Privy (auth + embedded wallets) — public app id
NEXT_PUBLIC_PRIVY_APP_ID=

# SERVER-ONLY (never exposed to the browser):
# gas relayer + escrow verification signer key
RELAYER_PK=
