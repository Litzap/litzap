# --- LitZap frontend env (copy to .env.local and fill in) ---
# NEXT_PUBLIC_* values are exposed to the browser. The keys WITHOUT that
# prefix are server-only secrets — never commit or log them.

# LiteForge (LitVM) RPC — chain 4441, gas token zkLTC
NEXT_PUBLIC_LITEFORGE_RPC=https://liteforge.rpc.caldera.xyz/http

# Deployed LitZap contracts (public, live on LiteForge) — pre-filled so the
# app runs out of the box against the live protocol.
NEXT_PUBLIC_REGISTRY=0x5F98A240De0a92620Fad513525c4F5f046b4A81D
NEXT_PUBLIC_PAY=0xE5bF48f6b6Ea117Cac3Fa7B5E466441778E28c9A
NEXT_PUBLIC_ESCROW=0x315Fd6effBd3aDbd1CfBc53BE5d6CFB32A23fE30
NEXT_PUBLIC_DROPS=0x1cF889Fd8e262b639Acf23B4E33c3cE5134b9d01
NEXT_PUBLIC_SUBS=0x9C4E9902173fB14A0CdC5B60F74E4Dbd55D5344B
NEXT_PUBLIC_CAPSULE=0x3F7b5DC6687761A8B49bC57B33183EB5150180b0

# Tokens — USDC on LiteForge (default token, 6 decimals)
NEXT_PUBLIC_USDC=0xd5118dEe968d1533B2A57aB66C266010AD8957fa

# Privy (auth + embedded wallets) — your app id from https://dashboard.privy.io
# Use your own app id and add your domain to Privy's allowed origins.
NEXT_PUBLIC_PRIVY_APP_ID=

# Optional: Spline scene URL for the animated background (blank = disabled)
NEXT_PUBLIC_SPLINE_URL=

# SERVER-ONLY (never exposed to the browser):
# Relayer private key — pays gas for users and signs escrow releases.
# Use a dedicated throwaway key funded only with gas.
RELAYER_PK=

# Privy app secret — used by /api/claim to verify a claimant owns the social
# handle before releasing escrowed funds. From the Privy dashboard.
PRIVY_APP_SECRET=
